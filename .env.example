# Servidor
PORT=3000
HOST=0.0.0.0
APP_URL=http://localhost:3000
JWT_SECRET=troque-por-uma-chave-grande-com-mais-de-32-caracteres
# PostgreSQL (local ou Neon)
# Para Neon, cole a connection string do console: https://console.neon.tech
DATABASE_URL="postgresql://usuario:senha@localhost:5432/mei_no_controle?schema=public"
DATA_FILE=./data/database.json
UPLOAD_DIR=./uploads
MAX_UPLOAD_MB=5

# Gateway Asaas
# Para testar local sem gateway real, mantenha PAYMENT_MOCK=true.
# Em produção, coloque PAYMENT_MOCK=false e informe sua chave real/sandbox do Asaas.
PAYMENT_MOCK=true
ASAAS_API_KEY=
ASAAS_BASE_URL=https://sandbox.asaas.com/api
ASAAS_WEBHOOK_TOKEN=troque-este-token-e-configure-no-webhook-ou-na-url
PLAN_PRICE=24.90
PLAN_NAME=Plano Pro MEI no Controle
TRIAL_DAYS=7

# Email (SMTP)
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=naoresponda@seudominio.com.br
SMTP_PASS=sua_senha_de_app
SMTP_FROM="MEI no Controle <naoresponda@seudominio.com.br>"
